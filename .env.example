# Database - Get from Supabase (https://supabase.com/docs/guides/database/connecting-to-postgres)
# Go to Project Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# OpenRouter - Get from https://openrouter.ai/keys
# This lets you query ChatGPT, Claude, Gemini, Perplexity, etc. through one API
OPENROUTER_API_KEY=sk-or-v1-...

# Anthropic - Get from https://console.anthropic.com/settings/keys
# Used for Haiku 4.5 to parse and structure the comparison results
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI - Get from https://platform.openai.com/api-keys
# Used for generating embeddings (concept similarity)
OPENAI_API_KEY=sk-...

# App URL - Change to your deployed URL in production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Force IPv4 DNS resolution (fixes ENETUNREACH on IPv6-only Supabase addresses)
NODE_OPTIONS=--dns-result-order=ipv4first

# Gemini API - Get grom https://aistudio.google.com/api-keys
GOOGLE_GEMINI_API_KEY=AI…
